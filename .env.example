# Flask
SECRET_KEY=replace_with_secure_secret_key_at_least_32_chars

# Database (Render PostgreSQL or local SQLite)
# For Render: use postgresql://user:password@host/dbname
# For local testing: leave empty to use SQLite
DATABASE_URL=

# SMTP (optional - leave empty for dev mode OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@example.com

# Gemini API for chatbot
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Deployment (set on Render)
PORT=5000
